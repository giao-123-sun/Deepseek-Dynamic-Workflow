{
  "name": "@deepseek-dynamic-workflow/cli",
  "version": "0.1.0",
  "description": "DeepSeek Dynamic Workflow: cache-first dynamic workflows for low-cost multi-agent runs with prompt-cache metrics, artifacts, and dashboards.",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "type": "module",
  "bin": {
    "ddw-agent": "./dist/index.js",
    "ddw-prefix": "./dist/prefix-cli.js",
    "ddw-reasonix-agent": "./dist/reasonix-agent.js",
    "ddw-report": "./dist/report.js",
    "ddw-dashboard": "./dist/dashboard.js",
    "ddw-demo-suite": "./dist/scripts/demo-suite.js",
    "ddw-release-audit": "./dist/scripts/release-audit.js",
    "ddw-release-pack": "./dist/scripts/release-pack.js",
    "ddw-setup-odw": "./dist/scripts/setup-odw.js",
    "cf-dw-agent": "./dist/index.js",
    "cf-dw-prefix": "./dist/prefix-cli.js",
    "cf-dw-reasonix-agent": "./dist/reasonix-agent.js",
    "cf-dw-report": "./dist/report.js",
    "cf-dw-dashboard": "./dist/dashboard.js",
    "cf-dw-demo-suite": "./dist/scripts/demo-suite.js",
    "cf-dw-release-audit": "./dist/scripts/release-audit.js",
    "cf-dw-release-pack": "./dist/scripts/release-pack.js",
    "cf-dw-setup-odw": "./dist/scripts/setup-odw.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "agent": "node ./dist/index.js",
    "reasonix-agent": "node ./dist/reasonix-agent.js",
    "prefix": "node ./dist/prefix-cli.js",
    "report": "node ./dist/report.js",
    "dashboard": "node ./dist/dashboard.js",
    "demo:list": "node ./dist/scripts/demo-suite.js --mode list",
    "demo:dashboards": "node ./dist/scripts/demo-suite.js --mode dashboards",
    "setup:odw": "node ./dist/scripts/setup-odw.js",
    "demo:run": "node ./dist/scripts/setup-odw.js --if-missing && node ./dist/scripts/demo-suite.js --mode run",
    "release:audit": "node ./dist/scripts/release-audit.js",
    "release:pack": "node ./dist/scripts/release-pack.js",
    "probe:cache": "node ./dist/scripts/cache-probe.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "reasonix": "^0.53.2",
    "repomix": "^1.14.1",
    "typescript": "^5.7.2"
  }
}
